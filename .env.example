PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/salary_management
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Comma-separated allowed frontend origins (CORS)
CLIENT_URLS=http://localhost:3000,https://www.salarymanagement.shop,https://salarymanagement.shop
# Set true when deployed behind a reverse proxy (nginx, Render, Railway, etc.)
TRUST_PROXY=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
